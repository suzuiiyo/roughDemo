{
    "configurations": [{
        "name": "MinGW",
        "intelliSenseMode": "gcc-x64",
        "compilerPath": "D:MinGW/mingw64/bin/x86_64-w64-mingw32-gcc.exe",
        "cStandard": "c11",
        "cppStandard": "c++17",
        "includePath": [
            // 下面路径中的 D:MinGw 部分需要替换成你的 MinGw-w64 安装路径
            "${workspaceFolder}/**",
            "D:MinGW/mingw64/x86_64-w64-mingw32/include",
            "D:MinGW/mingw64/lib/gcc/x86_64-w64-mingw32/7.3.0/include/c++",
            "D:MinGW/mingw64/lib/gcc/x86_64-w64-mingw32/7.3.0/include/c++/tr1"
        ],
        "defines": [
            "_DEBUG",
            "UNICODE",
            "_UNICODE",
            "__GNUC__=7",
            "__cdecl=__attribute__((__cdecl__))"
        ],
        "browse": {
            "path": [
                // 下面路径中的 D:MinGw 部分需要替换成你的 MinGw-w64 安装路径
                "${workspaceFolder}/**",
                "D:MinGW/mingw64/x86_64-w64-mingw32/include",
                "D:MinGW/mingw64/lib/gcc/x86_64-w64-mingw32/7.3.0/include/c++",
                "D:MinGW/mingw64/lib/gcc/x86_64-w64-mingw32/7.3.0/include/c++/tr1"
            ],
            "limitSymbolsToIncludedHeaders": true,
            "databaseFilename": ""
        }
    }],
    "version": 4
}

